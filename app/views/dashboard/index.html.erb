<% content_for :title, "Apps" %>

<div class="page-head">
  <h1>Apps</h1>
  <% if can?(:create, :apps) %>
    <%= button(text: "+ New app", href: new_app_path) %>
  <% end %>
</div>

  <table class="apps">
    <thead>
      <tr><th>App</th><th>Status</th><th>Ruby</th><th>Source</th><th>Last deploy</th><th></th></tr>
    </thead>
    <tbody>
      <% @apps.each do |app| %>
        <tr>
          <td>
            <%= link_to app.name, app_path(app), class: "apps__name" %>
            <div class="muted">
              <% if app.repo? %>
                <span class="mono"><%= app.deploy_path %></span>
              <% else %>
                <a href="<%= app.url %>" target="_blank" rel="noopener"><%= app.fqdn %></a>
              <% end %>
            </div>
          </td>
          <td><%= status_badge(@statuses[app.id] || { status: :unknown }) %></td>
          <td><%= app.repo? ? "—" : content_tag(:code, app.ruby_version) %></td>
          <td><% if app.git? %> <span class="muted"><%= app.git_branch %></span><% end %></td>
          <td>
            <% if (d = app.last_deployment) %>
              <%= deployment_badge(d) %>
              <span class="muted"><%= time_ago_in_words(d.created_at) %> ago</span>
            <% else %>
              <span class="muted">never</span>
            <% end %>
          </td>
          <td class="row-actions">
            <% if can?(:update, :apps) %>
              <%= button_to "Deploy", deploy_app_path(app), class: "btn btn--small" %>
            <% end %>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
