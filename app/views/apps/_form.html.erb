<%= form_with model: app, html: { multipart: true }, builder: CustomFormBuilder do |f| %>
  <% if app.errors.any? %>
    <div class="flash flash--alert">
      <%= app.errors.full_messages.to_sentence %>
    </div>
  <% end %>

  <%= f.hidden_field :app_kind %>
  <p class="hint">
    Type: <strong><%= app.repo? ? "Repo (git pull + commands)" : "Rails app (Plesk subdomain)" %></strong>
  </p>

  <%= f.text_field :name, label: "Display name" %>

  <% if app.repo? %>
    <%# ---- plain git repo: pull to a path, run follow-up commands ---- %>
    <fieldset>
      <legend>Git source</legend>
      <label><span>Repo URL</span><%= f.text_field :git_repo_url, label: false, placeholder: "https://github.com/you/repo.git" %></label>
      <label><span>Branch</span><%= f.text_field :git_branch, label: false, placeholder: "main" %></label>
    </fieldset>

    <label><span>Checkout path</span><%= f.text_field :deploy_path, label: false, class: "mono", placeholder: "/var/www/vhosts/ltvb.nl/shared/ui-components" %></label>
    <p class="hint">Absolute path on the server where this repo is pulled (<code>git reset --hard</code>).</p>

    <label><span>Follow-up commands</span><%= f.text_area :post_deploy_commands, rows: 6, class: "mono", placeholder: "npm ci\nnpm run build" %></label>
    <p class="hint">One command per line, run in order from the checkout path after the pull (login shell, so <code>nvm</code>/<code>node</code> are available). Lines starting with <code>#</code> are ignored.</p>

    <label><span>.env (optional)</span><%= f.text_area :env_text, rows: 4, class: "mono", placeholder: "KEY=value" %></label>
  <% else %>
    <%# ---- Plesk-served Rails app (original behaviour) ---- %>
    <div class="form-row">
      <%= f.text_field :subdomain, placeholder: "login", label: "Subdomain" %>
      <%= f.select :domain, %w[ltvb.nl lucasvanbriemen.nl], { include_blank: false }, label: "Domain" %>
    </div>

    <%= f.text_field :ruby_version, placeholder: "3.3.8", label: "Ruby version" %>

    <div class="form-row">
      <label><span>Source mode</span><%= f.select :source_mode, App::SOURCE_MODES %></label>
      <label><span>Primary DB</span><%= f.select :primary_db_kind, App::PRIMARY_DB_KINDS %></label>
    </div>
    <p class="hint">Choose <code>external</code> if the primary DB is a shared/remote DB (e.g. MySQL). The deploy will never auto-migrate it.</p>

    <fieldset>
      <legend>Git source</legend>
      <label><span>Repo URL</span><%= f.text_field :git_repo_url, label: false, placeholder: "https://github.com/you/app.git" %></label>
      <label><span>Branch</span><%= f.text_field :git_branch, label: false, placeholder: "main" %></label>
    </fieldset>

    <% if app.upload? || app.new_record? %>
      <fieldset>
        <legend>Upload source (tar.gz)</legend>
        <label><span>Tarball</span><%= file_field_tag :tarball, accept: ".gz,.tgz,.tar.gz" %></label>
        <p class="hint">Only used when source mode is <code>upload</code>. Provide on create or each deploy.</p>
      </fieldset>
    <% end %>

    <label><span>config/master.key</span><%= f.text_area :master_key, rows: 1, class: "mono", placeholder: "32-char hex (leave blank if app needs no credentials)" %></label>

    <label><span>.env</span><%= f.text_area :env_text, rows: 6, class: "mono", placeholder: "DB_HOST=...\nDB_DATABASE=..." %></label>
  <% end %>

  <label><span>Notes</span><%= f.text_area :notes, rows: 2 %></label>

  <div class="form-actions">
    <%= f.submit (app.new_record? ? (app.repo? ? "Create & deploy repo" : "Create & deploy") : "Save"), class: "btn btn--primary" %>
    <%= link_to "Cancel", (app.new_record? ? root_path : app_path(app)), class: "btn" %>
  </div>
<% end %>
